# ─── Database ───
# PostgreSQL connection string (Neon recommended — free tier). For local dev you
# can run a local Postgres and point this at it. Run `npx prisma db push` after
# setting this to create the tables (incl. the CMS tables).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# ─── Auth (NextAuth) ───
# REQUIRED — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Public URL of the app (no trailing slash). Often auto-detected on Vercel/Netlify.
AUTH_URL="http://localhost:3000"

# Single CMS admin login (Part 8). Hash the password with bcrypt.
ADMIN_EMAIL="admin@yoursite.com"
ADMIN_PASSWORD_HASH=""

# ─── Deploy: Vercel (primary) ───
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""
VERCEL_PROJECT_ID=""
VERCEL_DEPLOY_HOOK_URL=""

# ─── Deploy: Netlify (optional) ───
NETLIFY_TOKEN=""
NETLIFY_SITE_ID=""
NETLIFY_HOOK_ID=""

# ─── Media ───
MEDIA_PROVIDER="local"   # local | cloudinary | s3
CLOUDINARY_URL=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Misc ───
AUTO_DEPLOY="false"      # auto-deploy when content is published

# ─── Performance proof (before/after Lighthouse) ───
# Free Google PageSpeed Insights API key (Google Cloud → enable "PageSpeed
# Insights API" → create API key). Without it, measurements hit a tiny shared
# quota and fail. Free tier is 25k/day.
PAGESPEED_API_KEY=""

# Note: deploy tokens entered in the admin Settings page are stored in the
# database and take precedence over these env values.
