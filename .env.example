# ─── Required for production (Netlify / Vercel → Environment Variables) ───

# PostgreSQL connection string (Neon recommended — free tier)
# 1. Create a project at https://neon.tech
# 2. Copy the connection string (pooled URL works best on serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public URL of your deployed app (no trailing slash)
# Netlify example:  https://your-site.netlify.app
# Vercel example:  https://your-app.vercel.app
AUTH_URL="https://your-site.netlify.app"

# ─── Local development ───
# Copy this file to .env and fill in the values above.

# Optional deploy integrations
# NETLIFY_CLIENT_ID=
# NETLIFY_CLIENT_SECRET=
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=