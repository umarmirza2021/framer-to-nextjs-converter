# ─── Required for Vercel (Settings → Environment Variables) ───

# PostgreSQL connection string (Neon recommended — free tier works with Vercel)
# 1. Create a project at https://neon.tech
# 2. Copy the connection string (use the pooled URL for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public URL of your deployed app (no trailing slash)
AUTH_URL="https://your-app.vercel.app"

# ─── Local development ───
# Use the same Neon database, or a separate Neon branch/dev database.
# SQLite is no longer used — PostgreSQL is required for local + production.

# Phase 2+ (deploy integrations)
# NETLIFY_CLIENT_ID=
# NETLIFY_CLIENT_SECRET=
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=