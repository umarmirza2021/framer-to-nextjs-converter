generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ProjectStatus: DRAFT | READY | DEPLOYED
// Platform: NETLIFY | VERCEL
// DeploymentStatus: PENDING | BUILDING | READY | FAILED

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  projects           Project[]
  deploymentAccounts DeploymentAccount[]
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  framerUrl      String
  title          String
  siteName       String
  status         String          @default("READY")
  stats          String
  filesJson      String
  previewHtml    String
  cacheId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deployments    Deployment[]

  @@index([userId])
}

model DeploymentAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  accessToken String
  accountName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, platform])
}

model Deployment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform  String
  url       String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// CMS (Framer-style content management)
// Field type:   text | rich-text | image | date | boolean | number | url | color | reference
// Page type:    index | detail
// Layer type:   text | image | background-image | href
// ─────────────────────────────────────────────────────────────

model CmsCollection {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  fields    CmsField[]
  items     CmsItem[]
  pages     CmsPage[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model CmsField {
  id           String        @id @default(cuid())
  collectionId String
  collection   CmsCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name         String
  key          String
  type         String
  required     Boolean       @default(false)
  defaultValue Json?
  sortOrder    Int           @default(0)

  @@unique([collectionId, key])
  @@index([collectionId])
}

model CmsItem {
  id           String        @id @default(cuid())
  collectionId String
  collection   CmsCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  slug         String
  data         Json
  published    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([collectionId, slug])
  @@index([collectionId])
}

model CmsPage {
  id           String        @id @default(cuid())
  collectionId String
  collection   CmsCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  pageType     String
  framerPageId String
  route        String
  bindings     CmsBinding[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([collectionId])
}

model CmsBinding {
  id           String  @id @default(cuid())
  pageId       String
  page         CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  layerId      String
  layerType    String
  collectionId String
  fieldKey     String
  pageType     String

  @@index([pageId])
}