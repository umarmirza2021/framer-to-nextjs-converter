generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ProjectStatus: DRAFT | READY | DEPLOYED
// Platform: NETLIFY | VERCEL
// DeploymentStatus: PENDING | BUILDING | READY | FAILED

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  projects           Project[]
  deploymentAccounts DeploymentAccount[]
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  framerUrl      String
  title          String
  siteName       String
  status         String          @default("READY")
  stats          String
  filesJson      String
  previewHtml    String
  cacheId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deployments    Deployment[]

  @@index([userId])
}

model DeploymentAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  accessToken String
  accountName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, platform])
}

model Deployment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform  String
  url       String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}